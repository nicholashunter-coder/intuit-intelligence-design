# Slack App tokens — get these from https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token
SLACK_SIGNING_SECRET=your-signing-secret

# LLM API key (OPTIONAL — bot works without it using keyword search)
# When set, answers are generated by the LLM instead of raw doc excerpts.
# Supports OpenAI or any OpenAI-compatible endpoint (e.g. Ollama).
# OPENAI_API_KEY=sk-your-openai-key

# GitHub PAT with repo write scope — for creating PRs
GITHUB_TOKEN=ghp_your-github-token
GITHUB_OWNER=nicholashunter-coder
GITHUB_REPO=intuit-intelligence-design

# Team members to tag when the bot can't answer (Slack user IDs)
# Comma-separated, e.g. U12345678,U87654321
ESCALATION_USERS=
